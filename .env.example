# CityBCP Command Center — Environment Variables
# Copy this file to .env:  cp .env.example .env

# Required for AI features (chat, insights)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Super Admin credentials (created on first boot)
# IMPORTANT: Change password for production!
SUPER_ADMIN_USER=admin
SUPER_ADMIN_PASS=admin123
SUPER_ADMIN_EMAIL=admin@example.com

# JWT Secret (optional — auto-generates if not set)
# Generate with: openssl rand -hex 32
JWT_SECRET=

# CORS allowed origins (comma-separated)
# Add your production domain here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,https://bcpcmd.citygpt.xyz

# Data directory
DATA_DIR=./db
